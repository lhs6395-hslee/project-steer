{
  "title": "Executor_Output",
  "description": "Executor가 생성하는 실행 결과 (v2.1 — Constraint-Aware, plan field removed)",
  "type": "object",
  "required": ["constraint_compliance", "outputs", "status", "artifacts"],
  "properties": {
    "constraint_compliance": {
      "type": "object",
      "required": ["constraints_checked", "violations"],
      "properties": {
        "constraints_checked": { "type": "array", "items": { "type": "string" } },
        "violations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "action", "result", "status"],
        "properties": {
          "step_id": { "type": "integer" },
          "action": { "type": "string" },
          "result": { "type": "string" },
          "status": { "type": "string", "enum": ["completed", "skipped", "failed", "blocked_by_constraint"] },
          "deviation": { "type": "string" },
          "constraint_check": { "type": "string" }
        }
      }
    },
    "retry_fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "fix_applied", "verified"],
        "properties": {
          "issue": { "type": "string" },
          "fix_applied": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "status": { "type": "string", "enum": ["completed", "partial", "failed"] },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "deviations": { "type": "array", "items": { "type": "string" } },
    "parallel_execution": {
      "type": "object",
      "properties": {
        "total_steps": { "type": "integer" },
        "successful_steps": { "type": "integer" },
        "failed_steps": { "type": "array", "items": { "type": "integer" } },
        "step_details": { "type": "array" }
      }
    }
  }
}
