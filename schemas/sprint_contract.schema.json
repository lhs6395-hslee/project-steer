{
  "title": "Sprint_Contract",
  "description": "Planner가 생성하고 Generator/Evaluator가 합의하는 작업 계약",
  "type": "object",
  "required": ["id", "created_at", "goal", "module", "files", "acceptance_criteria", "constraints", "impact_scope"],
  "properties": {
    "id": { "type": "string", "description": "UUID" },
    "created_at": { "type": "string", "description": "ISO 8601" },
    "goal": { "type": "string" },
    "module": { "type": "string", "enum": ["pptx", "docx", "wbs", "trello", "dooray", "gdrive", "datadog"] },
    "files": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "verification_method"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verification_method": { "type": "string", "enum": ["tool_check", "manual_review"] },
          "test_command": { "type": "string" }
        }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "impact_scope": {
      "type": "object",
      "properties": {
        "modules_affected": { "type": "array", "items": { "type": "string" } },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
      }
    },
    "risks": { "type": "array", "items": { "type": "string" } }
  }
}
