{
  "title": "Sprint_Contract",
  "description": "Planner가 생성하는 실행 계획",
  "type": "object",
  "required": ["task", "module", "steps", "acceptance_criteria", "risks"],
  "properties": {
    "task": { "type": "string" },
    "module": { "type": "string", "enum": ["pptx", "docx", "wbs", "trello", "dooray", "gdrive", "datadog"] },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "acceptance_criteria"],
        "properties": {
          "id": { "type": "integer" },
          "action": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "integer" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "estimated_complexity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } }
  }
}
