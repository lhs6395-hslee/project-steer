{
  "title": "Sprint_Contract",
  "description": "Planner가 생성하는 실행 계획",
  "type": "object",
  "required": ["task", "module", "mode", "steps", "acceptance_criteria", "risks"],
  "properties": {
    "task": { "type": "string" },
    "module": { "type": "string", "enum": ["pptx", "docx", "wbs", "trello", "dooray", "google_workspace", "datadog"] },
    "mode": { "type": "string", "enum": ["create", "modify"], "description": "create: 신규 생성, modify: 기존 파일 수정 (recon step 포함)" },
    "recon_step_id": { "type": "integer", "description": "mode=modify일 때 recon step의 id. Orchestrator가 이 step을 먼저 실행 후 나머지 병렬 시작" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "acceptance_criteria"],
        "properties": {
          "id": { "type": "integer" },
          "action": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "integer" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "estimated_complexity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "likelihood", "impact", "mitigation"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "likelihood": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    }
  }
}
